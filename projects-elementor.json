      "settings": {"padding":{"unit":"px","top":"96","right":"0","bottom":"96","left":"0","isLinked":false},"gap":"extended"},
      "elements": [
        {"id":"prjevimg","elType":"column","settings":{"_column_size":50},"elements":[
          {"id":"prjevimgw","elType":"widget","widgetType":"image","settings":{"image":{"url":"https://assets.zyrosite.com/cdn-cgi/image/format=auto,w=768,h=553,fit=crop/ALpeJ1OkE5HqbP9Z/truck-1-YKbrnR54Jlc0OQzq.jpg","id":""},"image_size":"full","width":{"unit":"%","size":100,"sizes":[]},"border_radius":{"unit":"px","top":"12","right":"12","bottom":"12","left":"12","isLinked":true}},"elements":[]}
