            {
              "id": "abtmishdg",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Dedicated to Leading the Transition to Clean Energy",
                "header_size": "h2",
                "typography_font_size": { "unit": "px", "size": 28, "sizes": [] },
                "typography_font_weight": "700",
                "_padding": { "unit": "px", "top": "0", "right": "0", "bottom": "16", "left": "0", "isLinked": false }
              },
              "elements": []
            },
            {
              "id": "abtmistxt",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>At Amerigroup, we are dedicated to leading the transition to clean energy by providing zero-emission solutions for transportation and energy production. Our mission is to reduce greenhouse gas emissions, improve the quality of energy supply, and support sustainable regional development.</p>",
                "typography_font_size": { "unit": "px", "size": 15, "sizes": [] }
              },
              "elements": []
            },
            {
              "id": "abtmisstats",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<div style=\"display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:32px;\"><div style=\"text-align:center;background:#e8f2fc;padding:28px 20px;border-radius:12px;\"><div style=\"font-size:2.2rem;font-weight:800;color:#0056A0;\">100<sup style=\"font-size:.9rem;\">+</sup></div><div style=\"font-size:.82rem;color:#555c6b;text-transform:uppercase;letter-spacing:.08em;margin-top:4px;\">Experience</div></div><div style=\"text-align:center;background:#e8f2fc;padding:28px 20px;border-radius:12px;\"><div style=\"font-size:2.2rem;font-weight:800;color:#0056A0;\">30<sup style=\"font-size:.9rem;\">+</sup></div><div style=\"font-size:.82rem;color:#555c6b;text-transform:uppercase;letter-spacing:.08em;margin-top:4px;\">Clients</div></div></div>"
