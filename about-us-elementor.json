              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p><span style=\"display:inline-block;font-size:.75rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#0056A0;background:#e8f2fc;padding:4px 14px;border-radius:20px;\">Our Mission</span></p>"
