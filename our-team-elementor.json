            {
              "id": "tm2bio",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Mr. Ken Wong, a Canadian-Chinese entrepreneur, serves as Corporate Vice President and Co-Founder of Amerigroup International, where he directs the company's global strategy and operations. His entrepreneurial journey spans commodity trading and mining across Canada, the USA, and Mexico. Notably, in 2012, he became the first Canadian-Chinese exporter of iron ore from Mexico to China — a milestone recognized by SGS. Since 2016, he has played a significant role in Belt and Road projects across Africa, contributing to initiatives in Gabon, Guinea, Cameroon, South Africa, and Morocco.</p>",
                "typography_font_size": { "unit": "px", "size": 14, "sizes": [] }
              },
              "elements": []
            }
          ]
