              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"text-align:center;font-size:1.1rem;\"><em>thrives on individuality and innovation.</em>&nbsp;<strong>We bring firsthand experience from collaborations with industry-leading clients and premier business partners, underscoring our commitment to excellence.</strong></p><p style=\"text-align:center;font-size:1.2rem;font-weight:700;font-style:italic;color:#0a3a8c;\">Our Team</p><ul style=\"list-style:none;display:flex;flex-direction:column;gap:10px;text-align:center;margin:0 auto;\"><li style=\"font-style:italic;font-weight:600;\">from engineering and project management to business development and operations</li><li style=\"font-style:italic;font-weight:600;\">ensuring every unique perspective drives our success in advancing sustainable energy solutions</li></ul>",
                "align": "center",
                "_padding": { "unit": "px", "top": "0", "right": "120", "bottom": "0", "left": "120", "isLinked": false }
